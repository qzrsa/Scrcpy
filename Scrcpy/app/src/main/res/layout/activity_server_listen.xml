<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="无 ADB 直连"
                android:textSize="18sp"
                android:textColor="@color/onBackground"
                android:gravity="center" />

            <View
                android:layout_width="45dp"
                android:layout_height="45dp" />

        </LinearLayout>

        <!-- 说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无需 ADB，数据直连\n被控端启动后，控制端通过 IP:端口 连接"
            android:textSize="14sp"
            android:textColor="@color/onBackgroundSecond"
            android:gravity="center"
            android:padding="16dp" />

        <!-- IP 地址 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本机 IP:"
                android:textColor="@color/onBackground" />

            <TextView
                android:id="@+id/ip_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/cyan"
                android:textSize="16sp"
                android:paddingStart="8dp"
                tools:text="192.168.1.100" />

            <ImageButton
                android:id="@+id/copy_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/copy"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="复制" />

        </LinearLayout>

        <!-- 端口号 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="端口: 25166"
                android:textColor="@color/onBackground"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- 状态指示 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <View
                android:id="@+id/status_indicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/background_circle_warn" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击启动等待连接"
                android:textColor="@color/onBackground"
                android:paddingStart="8dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 启动按钮 -->
        <Button
            android:id="@+id/start_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="启动"
            android:textSize="16sp"
            app:backgroundTint="@color/cyan" />

        <TextView
            android:id="@+id/start_button_text"
            android:visibility="gone"
            tools:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</layout>
