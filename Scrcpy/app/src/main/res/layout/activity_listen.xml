<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/background"
  android:orientation="vertical"
  tools:context=".ListenActivity">

  <!-- 返回按钮 -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingTop="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="5dp">

    <ImageView
      android:id="@+id/back_button"
      android:layout_width="54dp"
      android:layout_height="54dp"
      android:padding="15dp"
      android:src="@drawable/chevron_left"
      android:tint="@color/onBackground" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="5dp"
      android:text="P2P 等待连接"
      android:textColor="@color/onBackground"
      android:textSize="@dimen/largeFont"
      android:textStyle="bold" />

  </LinearLayout>

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingStart="15dp"
      android:paddingEnd="15dp">

      <!-- 状态指示 -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <View
          android:id="@+id/status_indicator"
          android:layout_width="80dp"
          android:layout_height="80dp"
          android:background="@drawable/background_circle_warn" />

        <TextView
          android:id="@+id/status_text"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="15dp"
          android:gravity="center"
          android:text="点击下方按钮启动监听"
          android:textColor="@color/onBackground"
          android:textSize="@dimen/middleFont" />

      </LinearLayout>

      <!-- 连接信息卡片 -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:background="@drawable/background_cron"
        android:orientation="vertical"
        android:paddingStart="15dp"
        android:paddingTop="15dp"
        android:paddingEnd="15dp"
        android:paddingBottom="15dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="连接信息"
          android:textColor="@color/onCardBackground"
          android:textSize="@dimen/middleFont"
          android:textStyle="bold" />

        <!-- IP 地址 -->
        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="15dp"
          android:text="IP 地址"
          android:textColor="@color/onCardBackgroundSecond"
          android:textSize="@dimen/smallFont" />

        <TextView
          android:id="@+id/ip_address"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="5dp"
          android:textColor="@color/onCardBackground"
          android:textSize="@dimen/middleFont"
          android:textStyle="bold"
          tools:text="192.168.1.100" />

        <!-- 端口 -->
        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="15dp"
          android:text="端口"
          android:textColor="@color/onCardBackgroundSecond"
          android:textSize="@dimen/smallFont" />

        <EditText
          android:id="@+id/port"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="5dp"
          android:digits="0123456789"
          android:inputType="number"
          android:maxLength="5"
          android:text="25166"
          android:textColor="@color/onCardBackground"
          android:textSize="@dimen/middleFont"
          android:textStyle="bold" />

        <!-- 复制按钮 -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="15dp"
          android:gravity="center"
          android:orientation="horizontal">

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="将 IP:端口 发送给控制端"
            android:textColor="@color/onCardBackgroundSecond"
            android:textSize="@dimen/smallFont" />

          <LinearLayout
            android:id="@+id/copy_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_round"
            android:backgroundTint="@color/button"
            android:gravity="center"
            android:paddingStart="15dp"
            android:paddingTop="8dp"
            android:paddingEnd="15dp"
            android:paddingBottom="8dp">

            <ImageView
              android:layout_width="18dp"
              android:layout_height="18dp"
              android:src="@drawable/copy"
              android:tint="@color/onButton" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="5dp"
              android:text="复制"
              android:textColor="@color/onButton"
              android:textSize="@dimen/smallFont" />

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- 使用说明 -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/background_cron"
        android:orientation="vertical"
        android:paddingStart="15dp"
        android:paddingTop="15dp"
        android:paddingEnd="15dp"
        android:paddingBottom="15dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="使用方法"
          android:textColor="@color/onCardBackground"
          android:textSize="@dimen/middleFont"
          android:textStyle="bold" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp"
          android:text="1. 点击下方「启动」按钮开始监听"
          android:textColor="@color/onCardBackgroundSecond"
          android:textSize="@dimen/smallFont" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="5dp"
          android:text="2. 将 IP:端口 发送给控制端"
          android:textColor="@color/onCardBackgroundSecond"
          android:textSize="@dimen/smallFont" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="5dp"
          android:text="3. 控制端通过 IP:端口 连接"
          android:textColor="@color/onCardBackgroundSecond"
          android:textSize="@dimen/smallFont" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="5dp"
          android:text="4. 无需 USB 连接，无需 ADB"
          android:textColor="@color/onCardBackgroundSecond"
          android:textSize="@dimen/smallFont" />

      </LinearLayout>

      <!-- 启动/停止按钮 -->
      <LinearLayout
        android:id="@+id/start_button"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/background_round"
        android:backgroundTint="@color/button"
        android:gravity="center">

        <ImageView
          android:layout_width="22dp"
          android:layout_height="22dp"
          android:src="@drawable/play"
          android:tint="@color/onButton" />

        <TextView
          android:id="@+id/start_button_text"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="8dp"
          android:text="启动"
          android:textColor="@color/onButton"
          android:textSize="@dimen/middleFont"
          android:textStyle="bold" />

      </LinearLayout>

    </LinearLayout>
  </ScrollView>

</LinearLayout>
